# =============================================================================
# Health Pal — Environment Variables Template
# Copy file ini ke `.env` di root project, lalu isi nilai yang sesuai.
# JANGAN commit file `.env` ke repository (lihat .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Backend)
# -----------------------------------------------------------------------------
# Ambil dari: https://app.supabase.com/project/<project-id>/settings/api
#   - Project URL  → "Project URL"
#   - anon key     → "Project API keys" → "anon / public"
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# Supabase (Service Role — BACKEND ONLY, JANGAN dipakai di client app)
# -----------------------------------------------------------------------------
# Hanya dipakai oleh Edge Functions / server-side scripts. JANGAN pernah
# di-expose ke Flutter app karena bypass Row Level Security (RLS).
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE=your-service-role-key-here
